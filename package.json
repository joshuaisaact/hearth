{
  "name": "hearth",
  "version": "0.1.0",
  "description": "Local-first Firecracker microVM sandboxes for AI agent development",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "hearth": "dist/cli/hearth.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "firecracker",
    "microvm",
    "sandbox",
    "agent",
    "ai",
    "local",
    "isolation"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.0"
  }
}
